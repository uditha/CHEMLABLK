// ChemLab LK — Prisma Schema
// PostgreSQL 16 | Prisma 5

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Language {
  en
  si
  ta
}

enum Difficulty {
  Easy
  Medium
  Hard
}

enum Priority {
  P1
  P2
  P3
}

enum ExperimentStatus {
  Built
  Next
  Planned
}

enum ExperimentMode {
  Guided
  Free
  Exam
  Mistake
  Teacher
}

enum UserRole {
  student
  teacher
  admin
}

// ─── School ───────────────────────────────────────────────────────────────────

model School {
  id        String   @id @default(cuid())
  name      String
  district  String
  province  String
  code      String   @unique
  createdAt DateTime @default(now())

  teachers Teacher[]
  students Student[]
}

// ─── Teacher ──────────────────────────────────────────────────────────────────

model Teacher {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  schoolId     String
  createdAt    DateTime @default(now())

  school  School    @relation(fields: [schoolId], references: [id])
  classes Class[]
}

// ─── Student ──────────────────────────────────────────────────────────────────

model Student {
  id          String   @id @default(cuid())
  indexNumber String   @unique
  name        String
  schoolId    String
  language    Language @default(en)
  classId     String?
  createdAt   DateTime @default(now())

  school    School               @relation(fields: [schoolId], references: [id])
  class     Class?               @relation(fields: [classId], references: [id])
  progress  ExperimentProgress[]
  quizResults QuizResult[]
}

// ─── Class ────────────────────────────────────────────────────────────────────

model Class {
  id        String   @id @default(cuid())
  name      String
  teacherId String
  createdAt DateTime @default(now())

  teacher     Teacher      @relation(fields: [teacherId], references: [id])
  students    Student[]
  assignments Assignment[]
}

// ─── Experiment ───────────────────────────────────────────────────────────────

model Experiment {
  id          String           @id @default(cuid())
  slug        String           @unique
  unit        Int
  title       String
  titleSi     String
  titleTa     String
  description String
  difficulty  Difficulty
  priority    Priority
  status      ExperimentStatus
  createdAt   DateTime         @default(now())

  progress    ExperimentProgress[]
  assignments Assignment[]
  questions   Question[]
}

// ─── ExperimentProgress ───────────────────────────────────────────────────────

model ExperimentProgress {
  id                String           @id @default(cuid())
  studentId         String
  experimentId      String
  mode              ExperimentMode  @default(Guided)
  modeCompletions   String[]        @default([]) // e.g. ["Guided", "Free", "Exam"]
  testedMetals      String[]        @default([]) // e.g. ["sodium", "potassium"]
  completed         Boolean         @default(false)
  score             Int             @default(0)
  bestScore         Int             @default(0)
  attempts          Int             @default(0)
  timeSpentSeconds  Int             @default(0)
  lastAttempt       DateTime        @default(now())

  student    Student    @relation(fields: [studentId], references: [id])
  experiment Experiment @relation(fields: [experimentId], references: [id])

  @@unique([studentId, experimentId])
}

// ─── Assignment ───────────────────────────────────────────────────────────────

model Assignment {
  id           String     @id @default(cuid())
  classId      String
  experimentId String
  dueDate      DateTime?
  createdAt    DateTime   @default(now())

  class      Class      @relation(fields: [classId], references: [id])
  experiment Experiment @relation(fields: [experimentId], references: [id])
}

// ─── Question ─────────────────────────────────────────────────────────────────

model Question {
  id            String     @id @default(cuid())
  experimentId  String
  questionText  String
  options       String[]
  correctAnswer Int
  explanation   String
  year          Int?
  difficulty    Difficulty

  experiment  Experiment   @relation(fields: [experimentId], references: [id])
  quizResults QuizResult[]
}

// ─── QuizResult ───────────────────────────────────────────────────────────────

model QuizResult {
  id             String   @id @default(cuid())
  studentId      String
  questionId     String
  selectedAnswer Int
  correct        Boolean
  createdAt      DateTime @default(now())

  student  Student  @relation(fields: [studentId], references: [id])
  question Question @relation(fields: [questionId], references: [id])
}
