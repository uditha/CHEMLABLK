# ============================================================
# ChemLab LK — Environment Variables
# Copy this to .env.local and fill in your values
# NEVER commit .env.local to version control
# ============================================================

# ── Database ─────────────────────────────────────────────────
# Must match docker-compose.yml (postgres service)
POSTGRES_USER=chemlab_user
POSTGRES_PASSWORD=chemlab_pass
POSTGRES_DB=chemlab_lk

# Full connection string (used by Prisma) — for local dev with Docker
DATABASE_URL="postgresql://chemlab_user:chemlab_pass@localhost:5432/chemlab_lk?schema=public"
# When running inside Docker, use:
# DATABASE_URL="postgresql://chemlab_user:chemlab_pass@postgres:5432/chemlab_lk?schema=public"

# ── NextAuth ─────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here_generate_with_openssl
NEXTAUTH_URL=http://localhost:3000

# ── Anthropic / Claude ───────────────────────────────────────
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ChemLab LK
NEXT_PUBLIC_APP_VERSION=1.0.0

# ── PgAdmin ──────────────────────────────────────────────────
PGADMIN_EMAIL=admin@chemlab.lk
PGADMIN_PASSWORD=pgadmin_password_here
